rules_version = '2';

// Reemplaza en Firebase Console → Firestore → Reglas → Publicar
//
// Versión abierta (sin login): todo el mundo puede leer/escribir cualquier documento.
// Solo para desarrollo o eventos cerrados; endurece reglas antes de exponer datos sensibles.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
